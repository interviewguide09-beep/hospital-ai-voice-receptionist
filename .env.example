# Project Core Configurations
PROJECT_NAME="Hospital AI Voice Receptionist"
ENV=development
DEBUG=True

# MySQL Database Settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=hospital_voice_db

# JWT Authentication Configurations
JWT_SECRET_KEY=YOUR_SECURE_JWT_SECRET_KEY_HERE
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Gemini LLM API Configurations
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# Twilio Voice Service Configurations
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_PHONE_NUMBER=YOUR_TWILIO_PHONE_NUMBER_HERE
TWILIO_WEBHOOK_URL=YOUR_PUBLIC_TUNNEL_OR_NGROK_DOMAIN
TEST_PHONE_NUMBER=YOUR_TEST_PHONE_NUMBER_HERE

# WhatsApp Notification Configurations (via Twilio WhatsApp API)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
RECEPTIONIST_WHATSAPP_NUMBER=whatsapp:+919999999999

# Payment Gateway URL
PAYMENT_BASE_URL=https://pay.cptiwari.com/appointment

# n8n Automation Service Configurations
N8N_WEBHOOK_URL=YOUR_N8N_WEBHOOK_URL_HERE
N8N_API_KEY=
